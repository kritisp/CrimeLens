# ── Application Configuration ────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_JSON=false
DEBUG=true

# ── API Specification ──────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1

# ── Cross-Origin Resource Sharing (CORS) ──────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173"]

# ── Security & Authentication (Generate new keys for production runs) ─────────
# command: openssl rand -hex 32
JWT_SECRET_KEY=INSECURE-DEV-SECRET-CHANGE-IN-PRODUCTION
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Database Layer ────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./crimelens.db

# ── ML Projections & Similarity Engines ────────────────────────────────────────
ML_MODEL_NAME=all-MiniLM-L6-v2
ML_DEVICE=cpu
ML_FAISS_INDEX_PATH=datasets/embeddings/cases.index
